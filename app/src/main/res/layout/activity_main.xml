<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/bg_main">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 顶部标题栏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="8dp"
            android:paddingBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/app_name"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/btn_settings"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/settings"
                android:src="@drawable/ic_settings"
                android:padding="8dp" />
        </LinearLayout>

        <!-- 第一部分：上传视频文件 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/section_upload_title"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:drawablePadding="8dp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/section_upload_subtitle"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:layout_marginBottom="12dp" />

        <!-- 上传区域卡片 -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_upload"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:id="@+id/layout_upload_area"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="32dp"
                android:background="@drawable/bg_upload_area">

                <!-- 视频图标 -->
                <ImageView
                    android:id="@+id/iv_video_icon"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:src="@drawable/ic_video"
                    android:layout_marginBottom="12dp"
                    android:contentDescription="@string/video_icon" />

                <!-- 提示文字（未选择视频时显示） -->
                <TextView
                    android:id="@+id/tv_upload_hint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/upload_hint"
                    android:textColor="@color/text_hint"
                    android:textSize="15sp"
                    android:gravity="center" />

                <!-- 已选视频信息（选择后显示） -->
                <LinearLayout
                    android:id="@+id/layout_video_info"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:visibility="gone">

                    <ImageView
                        android:id="@+id/iv_video_thumbnail"
                        android:layout_width="120dp"
                        android:layout_height="80dp"
                        android:scaleType="centerCrop"
                        android:background="@color/bg_card"
                        android:layout_marginBottom="8dp"
                        android:contentDescription="@string/video_thumbnail" />

                    <TextView
                        android:id="@+id/tv_video_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:maxLines="1"
                        android:ellipsize="middle"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/tv_video_detail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- 点击选择按钮 -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_select_video"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:layout_marginTop="16dp"
                    android:text="@string/btn_select_video"
                    android:textSize="14sp"
                    app:cornerRadius="22dp"
                    xmlns:app="http://schemas.android.com/apk/res-auto"
                    app:icon="@drawable/ic_folder"
                    app:iconGravity="textStart" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 第二部分：音频格式选择 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/section_format_title"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:drawablePadding="8dp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/section_format_subtitle"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:layout_marginBottom="12dp" />

        <!-- 格式选择网格 -->
        <LinearLayout
            android:id="@+id/layout_format_grid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="16dp">

            <!-- MP3 -->
            <LinearLayout
                android:id="@+id/format_mp3"
                style="@style/FormatCard"
                android:onClick="onFormatSelected">

                <TextView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:gravity="center"
                    android:text="@string/icon_mp3"
                    android:textColor="@color/format_mp3_color"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_format_icon" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/format_mp3"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginTop="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/format_mp3_desc"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp"
                    android:gravity="center" />
            </LinearLayout>

            <!-- AAC -->
            <LinearLayout
                android:id="@+id/format_aac"
                style="@style/FormatCard"
                android:onClick="onFormatSelected">

                <TextView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:gravity="center"
                    android:text="@string/icon_aac"
                    android:textColor="@color/format_aac_color"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_format_icon" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/format_aac"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginTop="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/format_aac_desc"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp"
                    android:gravity="center" />
            </LinearLayout>

            <!-- WAV -->
            <LinearLayout
                android:id="@+id/format_wav"
                style="@style/FormatCard"
                android:onClick="onFormatSelected">

                <TextView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:gravity="center"
                    android:text="@string/icon_wav"
                    android:textColor="@color/format_wav_color"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_format_icon" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/format_wav"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginTop="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/format_wav_desc"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp"
                    android:gravity="center" />
            </LinearLayout>

            <!-- FLAC -->
            <LinearLayout
                android:id="@+id/format_flac"
                style="@style/FormatCard"
                android:onClick="onFormatSelected">

                <TextView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:gravity="center"
                    android:text="@string/icon_flac"
                    android:textColor="@color/format_flac_color"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_format_icon" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/format_flac"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginTop="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/format_flac_desc"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp"
                    android:gravity="center" />
            </LinearLayout>

            <!-- M4A -->
            <LinearLayout
                android:id="@+id/format_m4a"
                style="@style/FormatCard"
                android:onClick="onFormatSelected">

                <TextView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:gravity="center"
                    android:text="@string/icon_m4a"
                    android:textColor="@color/format_m4a_color"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_format_icon" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/format_m4a"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginTop="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/format_m4a_desc"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp"
                    android:gravity="center" />
            </LinearLayout>
        </LinearLayout>

        <!-- 第三部分：音频质量设置 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/section_quality_title"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:drawablePadding="8dp"
            android:layout_marginBottom="8dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_bitrate"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp" />

                <Spinner
                    android:id="@+id/spinner_bitrate"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_spinner"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_sample_rate"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="8dp" />

                <Spinner
                    android:id="@+id/spinner_sample_rate"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_spinner"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 第四部分：提取处理 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/section_extract_title"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:drawablePadding="8dp"
            android:layout_marginBottom="12dp" />

        <!-- 开始提取按钮 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_extract"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/btn_extract"
            android:textSize="16sp"
            android:textColor="@android:color/white"
            android:enabled="false"
            app:cornerRadius="26dp"
            app:backgroundTint="@color/btn_extract_bg"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            app:icon="@drawable/ic_extract"
            app:iconGravity="textStart"
            app:iconTint="@android:color/white" />

        <!-- 进度区域 -->
        <LinearLayout
            android:id="@+id/layout_progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginTop="16dp"
            android:padding="16dp"
            android:background="@drawable/bg_progress_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <ProgressBar
                    android:id="@+id/progress_bar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp"
                    android:layout_height="8dp"
                    android:layout_weight="1"
                    android:max="100"
                    android:progress="0"
                    android:progressTint="@color/color_primary"
                    android:progressBackgroundTint="@color/progress_bg" />

                <TextView
                    android:id="@+id/tv_progress_percent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginStart="12dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_progress_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/status_preparing"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- 完成区域 -->
        <LinearLayout
            android:id="@+id/layout_complete"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginTop="16dp"
            android:padding="16dp"
            android:background="@drawable/bg_complete_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_success"
                    android:contentDescription="@string/success" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/status_complete"
                    android:textColor="@color/color_success"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_output_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginTop="8dp"
                android:layout_marginStart="32dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp"
                android:layout_marginStart="32dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_play"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="@string/btn_play"
                    android:textSize="13sp"
                    app:icon="@drawable/ic_play"
                    app:iconGravity="textStart"
                    xmlns:app="http://schemas.android.com/apk/res-auto" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_share"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="@string/btn_share"
                    android:textSize="13sp"
                    app:icon="@drawable/ic_share"
                    app:iconGravity="textStart"
                    xmlns:app="http://schemas.android.com/apk/res-auto" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_save"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="@string/btn_save"
                    android:textSize="13sp"
                    app:icon="@drawable/ic_save"
                    app:iconGravity="textStart"
                    xmlns:app="http://schemas.android.com/apk/res-auto" />
            </LinearLayout>
        </LinearLayout>

        <!-- 底部功能特点 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/section_features_title"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/feature_bullet"
                    android:textColor="@color/color_primary"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/feature_1"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginStart="6dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/feature_bullet"
                    android:textColor="@color/color_primary"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/feature_2"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginStart="6dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/feature_bullet"
                    android:textColor="@color/color_primary"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/feature_3"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginStart="6dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/feature_bullet"
                    android:textColor="@color/color_primary"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/feature_4"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginStart="6dp" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
